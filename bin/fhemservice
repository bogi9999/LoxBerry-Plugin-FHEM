#!/bin/bash

#
# FHEM service helper for LoxBerry
#

PLUGINNAME="fhem"

# Load LoxBerry environment
if [ -f /etc/environment ]; then
    set -a
    . /etc/environment
    set +a
fi

PATH="/sbin:/bin:/usr/sbin:/usr/bin:${LBHOMEDIR}/bin:${LBHOMEDIR}/sbin"

SERVICE="fhem.service"

is_running() {
    systemctl is-active --quiet "$SERVICE"
}

case "$1" in
    start)
        systemctl start "$SERVICE"
        ;;

    stop)
        systemctl stop "$SERVICE"
        ;;

    restart)
        systemctl restart "$SERVICE"
        ;;

    status)
        if is_running; then
            PID=$(pgrep -f "perl fhem.pl" | head -n1)
            if [ -n "$PID" ]; then
                echo "FHEM is running (PID $PID)"
            else
                echo "FHEM service is running."
            fi
            exit 0
        else
            echo "FHEM is stopped."
            exit 1
        fi
        ;;

    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 3
        ;;
esac

exit 0
